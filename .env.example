# Discord bot
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# FACEIT Open Data API key (both bot and api need this)
FACEIT_API_KEY=

# API server
API_PORT=8787

# Auth - required if NODE_ENV=production. If unset in dev, the API runs open (warning logged).
# Generate with: openssl rand -hex 32
API_KEY=

# CORS - comma-separated origins. DO NOT use `*` in production.
# Allow:
# - the Chrome extension popup/options: chrome-extension://<extension-id>
# - any Firefox install (random UUID per install): moz-extension://*
# - the content script (fetches from the page origin): https://www.faceit.com
# Leave empty in dev to rely on the default restrictive behavior.
API_CORS_ORIGINS=

# Rate limit - requests per minute per IP (default 60)
API_RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=info
