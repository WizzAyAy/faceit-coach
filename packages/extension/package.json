{
  "name": "@faceit-coach/extension",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Cross-browser web extension — FACEIT Coach companion popup for faceit.com",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:all": "wxt build && wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:all": "wxt zip && wxt zip -b firefox",
    "typecheck": "wxt prepare && vue-tsc --noEmit",
    "icons": "node scripts/generate-icons.mjs",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@faceit-coach/core": "workspace:*",
    "@vueuse/core": "^14.2.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@unocss/preset-icons": "^66.6.8",
    "@unocss/preset-uno": "^66.6.8",
    "@unocss/reset": "^66.6.8",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.8",
    "@wxt-dev/module-vue": "^1.0.3",
    "happy-dom": "^20.9.0",
    "unimport": "^6.1.1",
    "unocss": "^66.6.8",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7",
    "wxt": "^0.20.25"
  }
}
