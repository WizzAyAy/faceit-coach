{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "jsx": "preserve",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["unplugin-vue-components/types"],
    "outDir": "dist"
  },
  "include": [
    "src/**/*",
    "src/**/*.vue",
    "components.d.ts",
    ".wxt/wxt.d.ts",
    ".wxt/types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist", ".turbo", ".output"]
}
