{
  "name": "@faceit-coach/bot",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "FACEIT Coach Discord bot",
  "scripts": {
    "dev": "tsx --env-file=../../.env src/index.ts",
