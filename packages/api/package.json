{
  "name": "@faceit-coach/api",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "HTTP API proxying FACEIT — used by the Chrome extension and any external client",
  "scripts": {
    "dev": "tsx --env-file=../../.env --watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node --env-file=../../.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@faceit-coach/core": "workspace:*",
    "@hono/node-server": "^2.0.0",
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.12.15",
    "hono-rate-limiter": "^0.5.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  }
}
